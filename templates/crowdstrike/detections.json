{
  "template_id": "crowdstrike_detections_api",
  "name": "CrowdStrike Detections API",
  "category": "EDR",
  "description": "Bearer-token REST polling preset for CrowdStrike-style detection summaries with normalized IDs and timestamps.",
  "source_type": "HTTP_API_POLLING",
  "auth_type": "bearer",
  "tags": ["crowdstrike", "edr", "detections", "bearer"],
  "included_components": ["connector", "source", "stream", "mapping", "enrichment", "checkpoint", "route_suggestion"],
  "recommended_destinations": ["WEBHOOK_POST", "SYSLOG_TCP"],
  "connector_defaults": {
    "description": "CrowdStrike Detections collection",
    "auth_type": "bearer",
    "verify_ssl": true
  },
  "source_config_overlay": {},
  "stream_defaults": {
    "name": "Detections poll stream",
    "polling_interval": 60,
    "config_json": {
      "endpoint": "/detects/entities/detects/v2",
      "method": "GET",
      "timeout_seconds": 45,
      "retry_count": 2,
      "retry_backoff_seconds": 1.5
    },
    "rate_limit_json": {
      "max_requests": 30,
      "per_seconds": 60
    }
  },
  "mapping_defaults": {
    "event_array_path": "$.resources",
    "event_root_path": null,
    "field_mappings_json": {
      "event_id": "$.detection_id",
      "status": "$.status",
      "severity": "$.max_severity_displayname",
      "created_at": "$.created_timestamp",
      "hostname": "$.device.hostname"
    },
    "raw_payload_mode": "JSON"
  },
  "enrichment_defaults": {
    "enrichment_json": {
      "vendor": "CrowdStrike",
      "product": "FalconDetections",
      "log_type": "detection",
      "event_source": "crowdstrike_detections",
      "collector_name": "gdc-platform",
      "tenant": "default"
    },
    "override_policy": "KEEP_EXISTING",
    "enabled": true
  },
  "checkpoint_defaults": {
    "checkpoint_type": "CUSTOM_FIELD",
    "checkpoint_value_json": {
      "last_offset": null,
      "last_detection_id": null
    }
  },
  "route_suggestions": [
    {
      "failure_policy": "LOG_AND_CONTINUE",
      "formatter_config_json": {
        "message_format": "json"
      },
      "rate_limit_json": {
        "max_events": 600,
        "per_seconds": 1
      },
      "enabled": true
    }
  ],
  "setup_instructions": [
    "Set Host/Base URL to https://api.crowdstrike.com (or your cloud shard base URL).",
    "Paste an OAuth2 access token or API-scoped bearer token in credentials when instantiating.",
    "Adjust endpoint and query parameters to match your detections query workflow.",
    "Validate resources[] shape with API Test; tune JSONPaths if your API version differs.",
    "Add routes after mapping validation; enable the stream only when ready."
  ],
  "preview": {
    "sample_api_structure": {
      "resources": [
        {
          "detection_id": "ldt:123456",
          "status": "new",
          "max_severity_displayname": "High",
          "created_timestamp": "2026-05-11T08:22:11Z",
          "device": {
            "hostname": "WIN-CLIENT-01"
          }
        }
      ]
    },
    "checkpoint_strategy": "CUSTOM_FIELD for offset or last detection id; refine after observing API pagination.",
    "route_recommendations": "WEBHOOK_POST for SOAR, SYSLOG_TCP for centralized logging."
  }
}
