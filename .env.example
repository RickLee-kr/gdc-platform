# =============================================================================
# Generic Data Connector Platform — environment template (no real secrets)
# =============================================================================
# install.sh copies this file to ".env" when ".env" is missing (never overwrites).
# Never commit ".env". Database policy: PostgreSQL only (no SQLite fallback).
# =============================================================================

# --- REQUIRED (production platform stack) -------------------------------------
APP_ENV=production
APP_NAME=Generic Data Connector Platform API
API_PREFIX=/api/v1

POSTGRES_DB=datarelay
POSTGRES_USER=datarelay
POSTGRES_PASSWORD=change-me-strong-db-password

# Host-side tools (Alembic, scripts) against the platform postgres service (host port 55432):
DATABASE_URL=postgresql://datarelay:change-me-strong-db-password@127.0.0.1:55432/datarelay
#
# Inside the api container, docker-compose.platform.yml injects:
#   postgresql://datarelay:<POSTGRES_PASSWORD>@postgres:5432/datarelay

# --- REQUIRED (auth / encryption — replace before production exposure) --------
SECRET_KEY=change-me-in-production-use-long-random-string
JWT_SECRET_KEY=change-me-in-production-use-long-random-string
JWT_ALGORITHM=HS256
JWT_ISSUER=gdc-platform
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_MINUTES=1440
REQUIRE_AUTH=true
AUTH_DEV_HEADER_TRUST=false
ENCRYPTION_KEY=replace-with-fernet-or-aes-key-placeholder
DEFAULT_COLLECTOR_NAME=generic-connector-01

# --- OPTIONAL — bootstrap Administrator "admin" (create-only; see app/db/seed.py) ---
# When unset, first install uses password "admin" and requires password change on first login.
# When set, must be at least 8 characters; that value is used instead and does not force a change.
# GDC_SEED_ADMIN_PASSWORD=

# --- OPTIONAL — browser URL printed by scripts/release/install.sh -------------
# GDC_PUBLIC_URL=https://datarelay.example.com:18443/

# --- OPTIONAL — reverse proxy / TLS -------------------------------------------
# GDC_TRUST_PROXY_HEADERS=true
# GDC_PROXY_FORWARD_TRUSTED_HOSTS=*
# GDC_TLS_CERT_PATH=/var/gdc/tls/server.crt
# GDC_TLS_KEY_PATH=/var/gdc/tls/server.key
# GDC_PROXY_RELOAD_TOKEN=change-me-long-random-token
# GDC_PUBLIC_HTTPS_PORT=18443

# --- Published reverse-proxy ports (docker-compose.platform.yml defaults) -------
GDC_ENTRY_HTTP_PORT=18080
GDC_ENTRY_HTTPS_PORT=18443
GDC_PUBLIC_HTTPS_PORT=18443
# GDC_API_HOST_PORT=8000

# --- OPTIONAL — logging / diagnostics -----------------------------------------
# LOG_LEVEL=INFO

# --- OPTIONAL — development validation lab (NEVER enable in production) -------
# When ENABLE_DEV_VALIDATION_LAB=true and APP_ENV is not production/prod, the API
# defaults ENABLE_DEV_VALIDATION_S3, DATABASE_QUERY, and REMOTE_FILE to true unless
# you set them explicitly. Lab MinIO/SFTP credentials default for local fixtures.
ENABLE_DEV_VALIDATION_LAB=false
DEV_VALIDATION_AUTO_START=false
# ENABLE_DEV_VALIDATION_S3=true
# ENABLE_DEV_VALIDATION_DATABASE_QUERY=true
# ENABLE_DEV_VALIDATION_REMOTE_FILE=true
# MINIO_ENDPOINT=http://127.0.0.1:59000
# MINIO_ACCESS_KEY=gdcminioaccess
# MINIO_SECRET_KEY=gdcminioaccesssecret12
# DEV_VALIDATION_SFTP_PASSWORD=devlab123
# DEV_VALIDATION_SSH_SCP_PASSWORD=devlab456

# --- OPTIONAL — release / operator scripts ------------------------------------
# GDC_RELEASE_COMPOSE_FILE=docker-compose.platform.yml
# GDC_BACKUP_DIR=deploy/backups
# GDC_INSTALL_GENERATE_TLS=1
